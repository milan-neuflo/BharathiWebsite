---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const facilities = [
  {
    name: 'Clinical Simulation Labs',
    description: 'Equipped with high-fidelity mannequins and hospital-grade equipment for realistic bedside training and emergency response scenarios.',
    image: 'https://images.unsplash.com/photo-1551601651-2a8555f1a136?w=800&q=80',
    features: ['High-fidelity patient simulators', 'Hospital-grade monitoring equipment', 'Emergency response stations', 'Debriefing rooms'],
    size: 'large',
  },
  {
    name: 'Digital Library',
    description: 'A modern, air-conditioned library with over 15,000 volumes, e-journal access, and dedicated research terminals.',
    image: 'https://images.unsplash.com/photo-1521587760476-6c12a4b040da?w=800&q=80',
    features: ['15,000+ books & journals', 'E-library access 24/7', 'Research terminals', 'Quiet study zones'],
    size: 'small',
  },
  {
    name: 'Anatomy & Physiology Lab',
    description: 'Fully equipped with anatomical models, charts, and dissection facilities for comprehensive human body studies.',
    image: 'https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?w=800&q=80',
    features: ['3D anatomical models', 'Digital microscopy stations', 'Specimen collection', 'Interactive displays'],
    size: 'small',
  },
  {
    name: 'Community Health Center',
    description: 'An on-campus center where students gain real-world experience in primary healthcare delivery and community outreach programs.',
    image: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=800&q=80',
    features: ['Patient assessment rooms', 'Health education area', 'Outreach program base', 'Vaccination station'],
    size: 'medium',
  },
  {
    name: 'Computer Lab',
    description: 'State-of-the-art computer lab with healthcare software, statistical tools, and online learning platforms.',
    image: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=800&q=80',
    features: ['40+ workstations', 'Healthcare IT training', 'Statistical software', 'Online exam center'],
    size: 'medium',
  },
  {
    name: 'Auditorium & Seminar Halls',
    description: 'A 500-seat auditorium and multiple seminar halls equipped with AV systems for conferences, workshops, and guest lectures.',
    image: 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800&q=80',
    features: ['500-seat capacity', 'Full AV system', 'Video conferencing', 'Workshop spaces'],
    size: 'large',
  },
];

const hostelAmenities = [
  'Fully furnished rooms (2/3 sharing)',
  'Nutritious mess with South & North Indian cuisine',
  '24/7 security with CCTV surveillance',
  'Wi-Fi enabled campus',
  'Recreation room & indoor games',
  'Laundry facilities',
  'In-campus medical clinic',
  'Visitor lounge & common areas',
];

const galleryImages = [
  { src: 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=600&q=80', alt: 'Students in classroom' },
  { src: 'https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=600&q=80', alt: 'Practical session' },
  { src: 'https://images.unsplash.com/photo-1559757175-5700dde675bc?w=600&q=80', alt: 'Lab training' },
  { src: 'https://images.unsplash.com/photo-1631815588090-d4bfec5b1ccb?w=600&q=80', alt: 'Campus life' },
  { src: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=600&q=80', alt: 'Clinical training' },
  { src: 'https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=600&q=80', alt: 'Graduation day' },
  { src: 'https://images.unsplash.com/photo-1551601651-2a8555f1a136?w=600&q=80', alt: 'Simulation lab' },
  { src: 'https://images.unsplash.com/photo-1579684385127-1ef15d508118?w=600&q=80', alt: 'Hospital visit' },
];
---

<BaseLayout title="Facilities & Gallery | Bharathi College of Nursing" activeNav="Facilities">

  <!-- ============ HERO ============ -->
  <section class="relative py-32 overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1551601651-2a8555f1a136?w=1920&q=80"
      alt="Campus facilities"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-navy/90"></div>
    <div class="relative max-w-container mx-auto px-8 text-center flex flex-col items-center gap-6">
      <span class="font-work-sans font-semibold text-gold text-sm uppercase tracking-[2.8px]">Our Campus</span>
      <h1 class="font-newsreader italic text-5xl md:text-7xl text-white leading-tight">
        World-Class Facilities for<br />Future Healthcare Leaders
      </h1>
      <p class="text-[#d8e3fb] text-xl max-w-2xl leading-relaxed">
        Our campus is designed to provide an immersive learning environment that bridges the gap between classroom theory and clinical reality.
      </p>
    </div>
  </section>

  <!-- ============ FACILITIES BENTO GRID ============ -->
  <section class="bg-light-bg px-8 py-24">
    <div class="max-w-container mx-auto">
      <div class="mb-12 flex flex-col gap-2">
        <h2 class="font-newsreader italic text-4xl text-navy">Core Facilities</h2>
        <div class="w-24 h-1 bg-gold rounded"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {facilities.map((facility) => (
          <div class:list={[
            'bg-white rounded-lg overflow-hidden shadow-md group flex flex-col',
            facility.size === 'large' && 'md:col-span-2',
          ]}>
            <div class:list={['overflow-hidden', facility.size === 'large' ? 'h-72' : 'h-56']}>
              <img
                src={facility.image}
                alt={facility.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-8 flex flex-col gap-4 flex-1">
              <h3 class="font-newsreader italic text-2xl text-navy">{facility.name}</h3>
              <p class="text-text-secondary text-base leading-relaxed">{facility.description}</p>
              <ul class="grid grid-cols-2 gap-2 mt-auto pt-4 border-t border-gray-100">
                {facility.features.map((f) => (
                  <li class="flex items-center gap-2">
                    <svg class="w-3 h-3 text-gold flex-shrink-0" viewBox="0 0 12 12" fill="currentColor"><circle cx="6" cy="6" r="3"/></svg>
                    <span class="text-text-secondary text-sm">{f}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ HOSTEL & ACCOMMODATION ============ -->
  <section class="bg-navy px-8 py-24">
    <div class="max-w-container mx-auto flex flex-col lg:flex-row gap-16 items-center">
      <div class="flex-1 flex flex-col gap-8">
        <div class="flex flex-col gap-4">
          <span class="font-work-sans font-semibold text-gold text-sm uppercase tracking-[2.8px]">Student Living</span>
          <h2 class="font-newsreader italic text-5xl text-white leading-tight">
            Safe & Comfortable<br />Hostel Accommodation
          </h2>
          <p class="text-slate-400 text-lg leading-relaxed">
            Our hostel provides a secure, home-away-from-home environment exclusively for female students, with modern amenities designed to support academic focus and personal well-being.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {hostelAmenities.map((amenity) => (
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-slate-300 text-base">{amenity}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="w-full lg:w-[480px] flex-shrink-0">
        <div class="rounded-lg overflow-hidden shadow-2xl">
          <img
            src="https://images.unsplash.com/photo-1555854877-bab0e564b8d5?w=800&q=80"
            alt="Hostel accommodation"
            class="w-full h-auto object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ GALLERY ============ -->
  <section class="bg-blue-bg px-8 py-24">
    <div class="max-w-container mx-auto">
      <div class="text-center mb-16 flex flex-col items-center gap-4">
        <span class="font-work-sans font-semibold text-navy text-sm uppercase tracking-[2.8px]">Campus Life</span>
        <h2 class="font-newsreader italic text-5xl text-navy">Gallery</h2>
        <p class="text-text-secondary text-lg max-w-xl">
          A glimpse into the vibrant academic and campus life at Bharathi College of Nursing.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {galleryImages.map((img, i) => (
          <div class:list={[
            'rounded-lg overflow-hidden shadow-md group',
            i === 0 && 'md:col-span-2 md:row-span-2',
          ]}>
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500 aspect-square"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-[rgba(9,20,38,0.95)]"></div>
    <div class="relative max-w-5xl mx-auto text-center flex flex-col items-center gap-8 px-8">
      <h2 class="font-newsreader italic text-5xl text-white">Experience Our Campus</h2>
      <p class="text-text-muted text-xl max-w-2xl leading-relaxed">
        Schedule a campus visit to see our facilities firsthand and meet our faculty.
      </p>
      <div class="flex flex-wrap justify-center gap-6">
        <a href={`${base}/contact`} class="bg-gold text-gold-dark font-work-sans font-semibold text-lg px-10 py-5 rounded-md hover:bg-yellow-400 transition-colors">
          Schedule a Visit
        </a>
        <a href={`${base}/contact`} class="bg-white text-navy font-work-sans font-semibold text-lg px-10 py-5 rounded-md hover:bg-gray-100 transition-colors">
          Contact Admissions
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
